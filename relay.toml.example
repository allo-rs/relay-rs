# relay-rs 配置文件
# 默认路径: /etc/relay-rs/relay.toml

# ── 转发规则 ────────────────────────────────────────────────────────
# listen: 本机监听端口（单端口或端口段）
# to:     目标地址，格式 "host:port"
# proto:  tcp | udp | all（默认 all）
# ipv6:   true 则强制解析 IPv6（默认 false，优先 IPv4）
# comment: 备注（可选）

[[forward]]
listen = 10000
to = "example.com:443"
proto = "tcp"
comment = "转发 HTTPS"

[[forward]]
listen = 51820
to = "10.0.0.1:51820"
proto = "udp"
comment = "WireGuard 中转"

# 端口段：10000-10100 → 10.0.0.1:20000-20100
[[forward]]
listen = "10000-10100"
to = "10.0.0.1:20000"
proto = "tcp"
comment = "批量端口转发"

# ── 防火墙规则 ──────────────────────────────────────────────────────
# src:   源 IP 或 CIDR（可选）
# dst:   目标 IP 或 CIDR（可选）
# port:  目标端口（可选）
# proto: tcp | udp | all（默认 all）
# chain: input | forward（默认 input）
# ipv6:  true 则匹配 IPv6（默认 false）

[[block]]
src = "1.2.3.4"
comment = "封禁扫描 IP"

[[block]]
src = "192.168.100.0/24"
comment = "封禁整个网段"

[[block]]
port = 3306
proto = "tcp"
comment = "禁止外部访问 MySQL"

[[block]]
src = "2001:db8::1"
ipv6 = true
comment = "封禁 IPv6 地址"
