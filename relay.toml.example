# relay-rs 配置文件
# 默认路径: /etc/relay-rs/relay.toml

# ── 转发规则 ────────────────────────────────────────────────────────
# listen: 本机监听端口（单端口或端口段）
# to:     目标地址，格式 "host:port"
# proto:  tcp | udp | all（默认 all）
# ipv6:   true 则强制解析 IPv6（默认 false，优先 IPv4）
# comment: 备注（可选）

[[forward]]
listen = 10000
to = "example.com:443"
proto = "tcp"
comment = "转发 HTTPS"

[[forward]]
listen = 51820
to = "10.0.0.1:51820"
proto = "udp"
comment = "WireGuard 中转"

# 端口段：10000-10100 → 10.0.0.1:20000-20100
[[forward]]
listen = "10000-10100"
to = "10.0.0.1:20000"
proto = "tcp"
comment = "批量端口转发"

# ── 防火墙规则 ──────────────────────────────────────────────────────
# src:   源 IP 或 CIDR（可选）
# dst:   目标 IP 或 CIDR（可选）
# port:  目标端口（可选）
# proto: tcp | udp | all（默认 all）
# chain: input | forward（默认 input）
# ipv6:  true 则匹配 IPv6（默认 false）

[[block]]
src = "1.2.3.4"
comment = "封禁扫描 IP"

[[block]]
src = "192.168.100.0/24"
comment = "封禁整个网段"

[[block]]
port = 3306
proto = "tcp"
comment = "禁止外部访问 MySQL"

[[block]]
src = "2001:db8::1"
ipv6 = true
comment = "封禁 IPv6 地址"

# ── 面板配置 ────────────────────────────────────────────────────────
# mode:     node（被主控管理）| master（主控，含 Web 面板）
# listen:   监听地址，如 "0.0.0.0:9090"
# secret:   node 模式：API 认证 token；master 模式：JWT 签名密钥
# tls_cert/tls_key: 可选，不填自动生成自签名证书到 /etc/relay-rs/

# -- Node 模式示例 --
# [panel]
# mode = "node"
# listen = "0.0.0.0:9090"
# secret = "your-node-secret-token"

# -- Master 模式示例 --
# [panel]
# mode = "master"
# listen = "0.0.0.0:9090"
# secret = "your-jwt-signing-secret"   # 必须足够随机
#
# [panel.auth]
# username = "admin"
# password = "$2b$12$..."              # 用 relay-rs panel-passwd 命令生成
#
# [[panel.nodes]]
# name  = "节点1-香港"
# url   = "https://1.2.3.4:9090"
# token = "node1-secret-token"
#
# [[panel.nodes]]
# name  = "节点2-日本"
# url   = "https://5.6.7.8:9090"
# token = "node2-secret-token"
